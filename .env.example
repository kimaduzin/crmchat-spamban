# ====================================================================
# spamban — конфигурация. Скопируй этот файл в .env и заполни значения.
#   cp .env.example .env
# Или запусти ./setup.sh — он сделает это интерактивно и провалидирует
# креды.
# ====================================================================

# --- CRMchat API ---
# Личный API-ключ CRMchat. Получить:
#   https://app.crmchat.ai → правый верх → Settings → API keys → Create
# Ключ начинается с sk_
CRMCHAT_TOKEN=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID воркспейса, в котором живут Telegram-аккаунты.
# Где взять (любой из вариантов):
#   1. В URL CRMchat после логина: https://app.crmchat.ai/w/<WORKSPACE_ID>/...
#   2. Через API:
#      curl -s -H "Authorization: Bearer $CRMCHAT_TOKEN" \
#        "https://api.crmchat.ai/v1/workspaces?organizationId=<ORG_ID>"
#   3. Запустить ./setup.sh — он покажет все доступные воркспейсы.
WORKSPACE_ID=ws_xxxxxxxxxxxxxxxxxxxx

# --- Telegram-бот для уведомлений ---
# Создаётся отдельно (один раз, общий для всех проверок):
#   1. Открой @BotFather → /newbot → имя → username → получишь токен.
#   2. Напиши боту /start (или добавь в группу/канал, где будут алерты).
NOTIFY_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Куда бот будет слать сводки и алерты.
# Где взять chat_id:
#   - Личка: открой https://api.telegram.org/bot<NOTIFY_BOT_TOKEN>/getUpdates
#     после того как написал боту → ищи "chat":{"id": <число>}.
#   - Группа: добавь бота в группу, отправь любое сообщение,
#     открой тот же getUpdates → chat.id, для групп начинается с -100...
NOTIFY_CHAT_ID=123456789

# ====================================================================
# Параметры запуска. Эти переменные обычно задаются не здесь,
# а в systemd-юните / cron-задаче (по одной на каждое расписание),
# чтобы у разных запусков были разные SPAMBAN_RUN_LABEL и окно.
# Здесь их можно оставить закомментированными.
# ====================================================================

# Метка запуска (попадёт в заголовок сводки). Любая строка.
# SPAMBAN_RUN_LABEL=manual

# В течение скольки минут размазывать проверку аккаунтов
# (внутри окна они стартуют по очереди с рандомным джиттером).
# Чем больше аккаунтов — тем шире надо ставить окно.
# SPAMBAN_WINDOW_MINUTES=60

# Сухой прогон: не шлём /start в @SpamBot, только проверяем доступ
# и читаем историю. Полезно для отладки.
# SPAMBAN_DRY_RUN=0

# Сколько секунд ждать ответ от @SpamBot после /start.
# Дефолт 6 — норм для большинства случаев.
# SPAMBAN_REPLY_WAIT=6

# Ограничить проверку первыми N случайными аккаунтами (для smoke-теста).
# 0 = проверять всех.
# SPAMBAN_LIMIT=0
