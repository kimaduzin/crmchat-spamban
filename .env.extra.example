# Override-файл для ДОПОЛНИТЕЛЬНОГО воркспейса (если у тебя их несколько).
# Подключается ВТОРЫМ EnvironmentFile= после основного .env в systemd-юните,
# и любые ключи отсюда перебивают значения из .env.
#
# Минимум — задать только WORKSPACE_ID. Всё остальное (CRMCHAT_TOKEN,
# NOTIFY_BOT_TOKEN, NOTIFY_CHAT_ID) возьмётся из основного .env.
#
# Использование:
#   1. cp .env.extra.example /opt/spamban/.env.extra
#   2. отредактируй
#   3. подключи в systemd-юните (см. systemd/spamban-extra-morning.service)

WORKSPACE_ID=xxxxxxxxxxxxxxxxxxxx

# Если для этого воркспейса нужен отдельный чат для алертов — раскомментируй:
# NOTIFY_CHAT_ID=-1001234567890
